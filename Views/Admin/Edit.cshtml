@model Sedziowanie.ViewModels.EditUserViewModel

@{
    ViewData["Title"] = "Edytuj użytkownika";

    var rolesForSelect = Model.AvailableRoles
        .Select(r => new
        {
            Value = r,
            Text = r switch
            {
                "Sedzia" => "Sędzia",
                "User" => "Trener",
                _ => r
            }
        });
}

<div class="container mt-4" style="max-width: 540px;">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-user-edit me-2"></i>@ViewData["Title"]</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Imie" class="form-label fw-semibold">Imię</label>
                    <input asp-for="Imie" class="form-control" />
                    <span asp-validation-for="Imie" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Nazwisko" class="form-label fw-semibold">Nazwisko</label>
                    <input asp-for="Nazwisko" class="form-control" />
                    <span asp-validation-for="Nazwisko" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Role" class="form-label fw-semibold">Rola</label>
                    <select asp-for="Role" asp-items="@(new SelectList(rolesForSelect, "Value", "Text", Model.Role))" class="form-select"></select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save me-1"></i> Zapisz
                    </button>
                    <a asp-action="ShowUsers" class="btn btn-outline-secondary">
                        <i class="fas fa-times me-1"></i> Anuluj
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
