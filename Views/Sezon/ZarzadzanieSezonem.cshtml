@using Sedziowanie.Models
@{
    ViewData["Title"] = "Zarządzanie sezonem";
    var rozgrywki = ViewBag.Rozgrywki as List<Rozgrywki> ?? new List<Rozgrywki>();
    int meczeCount = ViewBag.MeczeCount as int? ?? 0;
    int niedyspCount = ViewBag.NiedyspozycjeCount as int? ?? 0;
}

<h2 class="mb-4">@ViewData["Title"]</h2>

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string errorMsg)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-circle me-2"></i>@errorMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">

    
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-success text-white">
                <i class="fas fa-file-excel me-2"></i><strong>Eksport do Excela</strong>
            </div>
            <div class="card-body">

                <h6 class="text-muted text-uppercase mb-2">Wszystkie mecze</h6>
                <a asp-action="ExportWszystkieMecze" class="btn btn-outline-success mb-3">
                    <i class="fas fa-download me-1"></i> Pobierz — Wszystkie mecze
                </a>

                <hr />

                <h6 class="text-muted text-uppercase mb-2">Pełny sezon</h6>
                <p class="text-muted small">Jeden plik z arkuszami: Wszystkie mecze, każda kategoria osobno, Statystyki sędziów.</p>
                <a asp-action="ExportPelnySezon" class="btn btn-success mb-3">
                    <i class="fas fa-file-excel me-1"></i> Pobierz — Pełny sezon
                </a>

                <hr />

                <h6 class="text-muted text-uppercase mb-2">Według kategorii</h6>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var r in rozgrywki)
                    {
                        <a asp-action="ExportKategoria" asp-route-id="@r.Id"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-download me-1"></i>@r.Nazwa
                        </a>
                    }
                    @if (!rozgrywki.Any())
                    {
                        <span class="text-muted small">Brak rozgrywek.</span>
                    }
                </div>
            </div>
        </div>
    </div>

    
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <i class="fas fa-file-import me-2"></i><strong>Import meczów z Excela</strong>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Importuj mecze z pliku <code>.xlsx</code> w formacie eksportu.
                    Arkusz <em>Wszystkie mecze</em> zostanie odczytany. Rozgrywki nieznane zostaną utworzone.
                    Sędziowie dopasowani po formacie <em>Imię Nazwisko</em> — jeśli brak w bazie, pole będzie puste.
                </p>
                <form asp-action="ImportMecze" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Plik Excel (.xlsx)</label>
                        <input type="file" name="file" accept=".xlsx" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-upload me-1"></i> Importuj mecze
                    </button>
                </form>
            </div>
        </div>
    </div>

    
    <div class="col-12">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <i class="fas fa-calendar-times me-2"></i><strong>Zakończ sezon</strong>
            </div>
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <p class="mb-1">
                            Aktualnie w bazie: <strong>@meczeCount meczów</strong> i <strong>@niedyspCount niedyspozycji</strong>.
                        </p>
                        <p class="text-danger mb-2">
                            <i class="fas fa-exclamation-triangle me-1"></i>
                            Ta operacja <strong>trwale usunie wszystkie mecze i niedyspozycje</strong>.
                            Przed usunięciem zostanie automatycznie wygenerowana i pobrana kopia zapasowa
                            (plik ZIP z dwoma plikami Excel: pełny sezon i tylko mecze).
                        </p>
                        <p class="text-muted small mb-0">
                            Dane sędziów, rozgrywki i konta użytkowników <strong>nie zostaną usunięte</strong>.
                        </p>
                    </div>
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                        <button type="button" class="btn btn-danger"
                                data-bs-toggle="modal" data-bs-target="#modalZakonczSezon">
                            <i class="fas fa-calendar-times me-1"></i> Zakończ sezon
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>


<div class="modal fade" id="modalZakonczSezon" tabindex="-1" aria-labelledby="modalZakonczSezonLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="modalZakonczSezonLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i>Potwierdzenie zakończenia sezonu
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <strong>Uwaga!</strong> Zostaną usunięte:
                    <ul class="mb-0 mt-1">
                        <li>Wszystkie <strong>@meczeCount mecze</strong></li>
                        <li>Wszystkie <strong>@niedyspCount niedyspozycje</strong></li>
                    </ul>
                </div>
                <p>Przed usunięciem system automatycznie wygeneruje i pobierze kopię zapasową w formacie ZIP.</p>
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="chkConfirm" />
                    <label class="form-check-label" for="chkConfirm">
                        Rozumiem, że wszystkie mecze i niedyspozycje zostaną trwale usunięte.
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                <form asp-action="ZakonczSezon" method="post" id="formZakonczSezon">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="confirmed" value="true" />
                    <button type="submit" class="btn btn-danger" id="btnZakonczSezon" disabled>
                        <i class="fas fa-calendar-times me-1"></i> Zakończ sezon i pobierz kopię
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('chkConfirm').addEventListener('change', function () {
            document.getElementById('btnZakonczSezon').disabled = !this.checked;
        });
    </script>
}
