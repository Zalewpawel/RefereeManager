@model Sedziowanie.Models.Sedzia

@{
    ViewData["Title"] = "Informacje o sędzi";
    var stats = ViewBag.Stats as Sedziowanie.ViewModels.SedziaStatsDto;
}

<div class="container mt-3" style="max-width: 680px;">
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="fas fa-user me-2"></i>@Model.Imie @Model.Nazwisko
                @if (Model.CzyUrlop)
                {
                    <span class="badge bg-secondary ms-2">urlop</span>
                }
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-sm-6">
                    <div class="text-muted small">Klasa</div>
                    <strong>@Model.Klasa</strong>
                </div>
                <div class="col-sm-6">
                    <div class="text-muted small">Miasto</div>
                    <strong>@(Model.Miasto ?? "—")</strong>
                </div>
                <div class="col-sm-6">
                    <div class="text-muted small">Telefon</div>
                    <strong>@(Model.Telefon ?? "—")</strong>
                </div>
                <div class="col-sm-6">
                    <div class="text-muted small">Email</div>
                    <strong><a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a></strong>
                </div>
            </div>
        </div>
    </div>

    @if (stats != null)
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header">
                <h6 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Statystyki</h6>
            </div>
            <div class="card-body">
                <div class="row g-2 text-center">
                    <div class="col-4 col-sm-2">
                        <div class="border rounded p-2">
                            <div class="fs-5 fw-bold">@stats.MeczeCount</div>
                            <div class="text-muted small">Łącznie</div>
                        </div>
                    </div>
                    <div class="col-4 col-sm-2">
                        <div class="border rounded p-2">
                            <div class="fs-5 fw-bold">@stats.SiCount</div>
                            <div class="text-muted small">SI</div>
                        </div>
                    </div>
                    <div class="col-4 col-sm-2">
                        <div class="border rounded p-2">
                            <div class="fs-5 fw-bold">@stats.SiiCount</div>
                            <div class="text-muted small">SII</div>
                        </div>
                    </div>
                    <div class="col-4 col-sm-2">
                        <div class="border rounded p-2">
                            <div class="fs-5 fw-bold">@stats.SsCount</div>
                            <div class="text-muted small">SS</div>
                        </div>
                    </div>
                    <div class="col-4 col-sm-2">
                        <div class="border rounded p-2">
                            <div class="fs-5 fw-bold">@stats.SgCount</div>
                            <div class="text-muted small">SG</div>
                        </div>
                    </div>
                    <div class="col-4 col-sm-2">
                        <div class="border rounded p-2">
                            <div class="fs-5 fw-bold">@stats.LCount</div>
                            <div class="text-muted small">L</div>
                        </div>
                    </div>
                </div>

                @if (stats.DuetCount > 0)
                {
                    <div class="mt-3 text-muted small">
                        Najczęstszy duet: <strong>@stats.DuetSedzia (@stats.DuetCount meczów)</strong>
                    </div>
                }
            </div>
        </div>
    }

    <div class="d-flex gap-2">
        <a asp-action="MeczeSedziego" asp-route-sedziaId="@Model.Id" class="btn btn-outline-primary">
            <i class="fas fa-list me-1"></i> Mecze sędziego
        </a>
        <a asp-action="ShowAll" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Powrót do listy
        </a>
    </div>
</div>
