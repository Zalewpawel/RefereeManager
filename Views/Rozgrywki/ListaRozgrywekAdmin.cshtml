@model IEnumerable<Sedziowanie.Models.Rozgrywki>

@{
    ViewData["Title"] = "Lista Rozgrywek (Admin)";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h2 class="mb-0">@ViewData["Title"]</h2>
    <a class="btn btn-primary btn-sm" asp-controller="Rozgrywki" asp-action="Add">
        <i class="fas fa-plus-circle me-1"></i> Dodaj rozgrywki
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-bordered mb-0 text-center align-middle">
            <thead class="thead-softgray">
                <tr>
                    <th class="text-start">Nazwa</th>
                    <th style="width:220px;">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="text-start">
                            <a asp-action="MeczeRozgrywek" asp-route-rozgrywkiId="@r.Id"
                               class="text-decoration-none fw-semibold">
                                @r.Nazwa
                            </a>
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary me-1" asp-action="Edit" asp-route-id="@r.Id">
                                <i class="fas fa-pen me-1"></i> Edytuj
                            </a>
                            <form asp-action="Delete" method="post"
                                  onsubmit="return confirm('Na pewno usunąć rozgrywki: @r.Nazwa?');"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash me-1"></i> Usuń
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
