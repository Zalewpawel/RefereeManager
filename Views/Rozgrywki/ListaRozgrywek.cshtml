@model IEnumerable<Sedziowanie.Models.Rozgrywki>

@{
    ViewData["Title"] = "Lista Rozgrywek";
}

<h2>@ViewData["Title"]</h2>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-bordered mb-0 text-center align-middle">
            <thead class="thead-softgray">
                <tr>
                    <th>Nazwa rozgrywek</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rozgrywki in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="MeczeRozgrywek" asp-route-rozgrywkiId="@rozgrywki.Id"
                               class="text-decoration-none fw-semibold">
                                @rozgrywki.Nazwa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
