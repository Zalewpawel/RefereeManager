@using Sedziowanie.Models
@model Rozgrywki

@{
    ViewData["Title"] = "Dodaj Rozgrywki";
}

<div class="container mt-4" style="max-width: 480px;">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Dodaj Rozgrywki</h5>
        </div>
        <div class="card-body">
            <form asp-action="Add" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label for="Nazwa" class="form-label fw-semibold">Nazwa rozgrywek</label>
                    <input type="text" id="Nazwa" name="Nazwa" class="form-control" required maxlength="200" />
                    <div asp-validation-summary="All" class="text-danger small mt-1"></div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i> Dodaj rozgrywki
                    </button>
                    <a asp-action="ListaRozgrywekAdmin" class="btn btn-outline-secondary">Anuluj</a>
                </div>
            </form>
        </div>
    </div>
</div>
