@using Sedziowanie.ViewModels
@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Zmień hasło";
    var success = TempData["Success"] as string;
    bool forced = ViewBag.Forced as bool? ?? false;
}

<div class="container mt-4" style="max-width: 520px;">
    @if (forced)
    {
        <div class="alert alert-warning mb-3">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Wymagana zmiana hasła.</strong> Administrator wymusił zmianę hasła. Ustaw nowe hasło, aby kontynuować.
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-key me-2"></i>Zmień hasło</h5>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(success))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@success
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="alert alert-info mb-3 py-2">
                <strong><i class="fas fa-info-circle me-1"></i> Wymagania hasła:</strong>
                <ul class="mb-0 mt-1 ps-3 small">
                    <li>Co najmniej <strong>10 znaków</strong></li>
                    <li>Przynajmniej jedna <strong>wielka litera</strong> (A–Z)</li>
                    <li>Przynajmniej jedna <strong>mała litera</strong> (a–z)</li>
                    <li>Przynajmniej jedna <strong>cyfra</strong> (0–9)</li>
                    <li>Przynajmniej jeden <strong>znak specjalny</strong> (np. !@@#$%)</li>
                </ul>
            </div>

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="OldPassword" class="form-label fw-semibold"></label>
                    <input asp-for="OldPassword" class="form-control" autocomplete="current-password" />
                    <span asp-validation-for="OldPassword" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                    <input asp-for="NewPassword" class="form-control" autocomplete="new-password" id="newPasswordInput" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    <div id="passwordStrength" class="mt-1"></div>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i> Zmień hasło
                </button>
                @if (!forced)
                {
                    <a asp-controller="Start" asp-action="Index" class="btn btn-outline-secondary ms-2">Anuluj</a>
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const input = document.getElementById('newPasswordInput');
        const strengthDiv = document.getElementById('passwordStrength');

        function check(pwd) {
            const checks = [
                { ok: pwd.length >= 10, label: '10+ znaków' },
                { ok: /[A-Z]/.test(pwd), label: 'wielka litera' },
                { ok: /[a-z]/.test(pwd), label: 'mała litera' },
                { ok: /\d/.test(pwd), label: 'cyfra' },
                { ok: /[^a-zA-Z0-9]/.test(pwd), label: 'znak specjalny' }
            ];
            const passed = checks.filter(c => c.ok).length;
            const color = passed <= 2 ? 'danger' : passed <= 4 ? 'warning' : 'success';
            const label = passed <= 2 ? 'Słabe' : passed <= 4 ? 'Średnie' : 'Silne';
            const missing = checks.filter(c => !c.ok).map(c => c.label);
            const missingHtml = missing.length ? `<small class="text-muted ms-2">Brakuje: ${missing.join(', ')}</small>` : '';
            strengthDiv.innerHTML = `<div class="d-flex align-items-center gap-2">
                <div class="progress flex-grow-1" style="height:6px">
                    <div class="progress-bar bg-${color}" style="width:${passed * 20}%"></div>
                </div>
                <small class="text-${color} fw-semibold">${label}</small>
                ${missingHtml}
            </div>`;
        }

        if (input) {
            input.addEventListener('input', () => check(input.value));
        }
    </script>
}
