@model Sedziowanie.ViewModels.AdminResetPasswordViewModel

@{
    ViewData["Title"] = "Ustaw nowe hasło";
}

<h2>@ViewData["Title"]</h2>

<p>Administrator wymusił reset hasła dla Twojego konta. Ustaw nowe hasło poniżej.</p>

<form asp-action="ResetPasswordByAdmin" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="UserId" type="hidden" />
    <input asp-for="Token" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="NewPassword" class="form-label"></label>
        <input asp-for="NewPassword" class="form-control" />
        <span asp-validation-for="NewPassword" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ConfirmPassword" class="form-label"></label>
        <input asp-for="ConfirmPassword" class="form-control" />
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Zapisz nowe hasło</button>
    <a asp-action="Login" class="btn btn-link">Powrót do logowania</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
