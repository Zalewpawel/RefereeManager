@model Sedziowanie.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Rejestracja użytkownika";
}

<div class="container mt-4" style="max-width: 540px;">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-user-plus me-2"></i>Rejestracja użytkownika</h5>
        </div>
        <div class="card-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" id="validationSummary"></div>

            <form asp-action="Register" method="post" id="registerForm">
                <div class="mb-3">
                    <label asp-for="Role" class="form-label fw-semibold">Rola</label>
                    <select asp-for="Role" class="form-select" id="roleSelect">
                        <option value="Admin">Admin</option>
                        <option value="Sedzia">Sędzia</option>
                        <option value="User">Trener</option>
                    </select>
                </div>

                <div class="mb-3" id="sedziaSelect" style="display: none;">
                    <label asp-for="SedziaId" class="form-label fw-semibold">Sędzia</label>
                    <select asp-for="SedziaId" class="form-select" id="sedziaDropdown"
                            asp-items="@(new SelectList(
                                            Model.AvailableSedziowie.Select(s => new { s.Id, FullName = s.Nazwisko + " " + s.Imie }),
                                            dataValueField: "Id",
                                            dataTextField: "FullName"
                                        ))">
                        <option value="">-- Wybierz sędziego --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Imie" class="form-label fw-semibold">Imię</label>
                    <input asp-for="Imie" class="form-control" id="imieInput" />
                    <span asp-validation-for="Imie" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Nazwisko" class="form-label fw-semibold">Nazwisko</label>
                    <input asp-for="Nazwisko" class="form-control" id="nazwiskoInput" />
                    <span asp-validation-for="Nazwisko" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" class="form-control" id="emailInput" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold">Hasło</label>
                    <input asp-for="Password" type="password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold">Potwierdź hasło</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-user-check me-1"></i> Zarejestruj
                    </button>
                    <a asp-controller="Admin" asp-action="ShowUsers" class="btn btn-outline-secondary">Anuluj</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const roleSelect = document.getElementById("roleSelect");
        const sedziaSelectDiv = document.getElementById("sedziaSelect");
        const imieInput = document.getElementById("imieInput");
        const nazwiskoInput = document.getElementById("nazwiskoInput");
        const emailInput = document.getElementById("emailInput");

        function onRoleChange() {
            const isSedzia = roleSelect.value === "Sedzia";
            sedziaSelectDiv.style.display = isSedzia ? "block" : "none";
            imieInput.readOnly = isSedzia;
            nazwiskoInput.readOnly = isSedzia;
            emailInput.readOnly = isSedzia;
            if (!isSedzia) {
                imieInput.readOnly = false;
                nazwiskoInput.readOnly = false;
                emailInput.readOnly = false;
            }
        }

        roleSelect.addEventListener("change", onRoleChange);
        onRoleChange();

        document.getElementById("sedziaDropdown").addEventListener("change", function () {
            const sid = this.value;
            if (!sid) return;
            fetch(`/Account/GetSedziaData?sid=${sid}`)
                .then(r => r.json())
                .then(data => {
                    imieInput.value = data.imie;
                    nazwiskoInput.value = data.nazwisko;
                    emailInput.value = data.email;
                });
        });
    </script>
}
